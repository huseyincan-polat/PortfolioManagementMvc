<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Portfolio Takip</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary:      #6366f1;
            --primary-dark: #4f46e5;
            --accent:       #a5b4fc;
            --bg:           #0f0f1a;
            --surface:      #1a1a2e;
            --surface2:     #22223b;
            --border:       rgba(99,102,241,0.2);
            --text:         #e2e8f0;
            --text-muted:   #94a3b8;
            --success:      #10b981;
            --danger:       #f43f5e;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }
        .site-nav {
            background: rgba(26,26,46,0.9);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            padding: .85rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 999;
        }
        .site-nav .brand {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--accent);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: .5rem;
        }
        .site-nav .brand::before { content: "📈"; }
        .site-nav .nav-links { display: flex; gap: 1.5rem; list-style: none; }
        .site-nav .nav-links a {
            color: var(--text-muted);
            text-decoration: none;
            font-size: .9rem;
            font-weight: 500;
            transition: color .2s;
        }
        .site-nav .nav-links a:hover { color: var(--accent); }
        .main-container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 2.5rem 1.5rem 4rem;
        }
        .page-header { margin-bottom: 2rem; }
        .page-header h1 {
            font-size: 2rem;
            font-weight: 700;
            background: linear-gradient(135deg, #a5b4fc, #6366f1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .page-header p { color: var(--text-muted); margin-top: .4rem; }
        .glass-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 2rem;
            box-shadow: 0 8px 32px rgba(0,0,0,.4);
        }
        .styled-table { width: 100%; border-collapse: collapse; font-size: .93rem; }
        .styled-table thead tr {
            background: linear-gradient(135deg, var(--primary-dark), var(--primary));
        }
        .styled-table thead th {
            padding: .85rem 1.2rem;
            font-weight: 600;
            color: #fff;
            text-align: left;
            letter-spacing: .04em;
            text-transform: uppercase;
            font-size: .78rem;
        }
        .styled-table thead th:first-child { border-radius: 8px 0 0 8px; }
        .styled-table thead th:last-child  { border-radius: 0 8px 8px 0; }
        .styled-table tbody tr { border-bottom: 1px solid var(--border); transition: background .18s; }
        .styled-table tbody tr:hover { background: rgba(99,102,241,.08); }
        .styled-table tbody td { padding: .9rem 1.2rem; color: var(--text); }
        .badge-year {
            display: inline-block;
            padding: .25em .7em;
            background: rgba(99,102,241,.15);
            border: 1px solid var(--border);
            border-radius: 99px;
            font-size: .82rem;
            color: var(--accent);
            font-weight: 500;
        }
        .btn-primary-custom {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: #fff;
            border: none;
            padding: .55rem 1.3rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: .88rem;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            transition: transform .15s, box-shadow .15s;
        }
        .btn-primary-custom:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(99,102,241,.4);
            color: #fff;
        }
        .btn-secondary-custom {
            background: transparent;
            color: var(--text-muted);
            border: 1px solid var(--border);
            padding: .55rem 1.3rem;
            border-radius: 8px;
            font-weight: 500;
            font-size: .88rem;
            text-decoration: none;
            display: inline-block;
            transition: border-color .15s, color .15s;
        }
        .btn-secondary-custom:hover { border-color: var(--accent); color: var(--accent); }
        .btn-danger-custom {
            background: linear-gradient(135deg, var(--danger), #be123c);
            color: #fff;
            border: none;
            padding: .55rem 1.3rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: .88rem;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            transition: transform .15s;
        }
        .btn-danger-custom:hover { transform: translateY(-1px); color: #fff; }
        .form-group { margin-bottom: 1.4rem; }
        .form-label {
            display: block;
            font-size: .85rem;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: .45rem;
            letter-spacing: .04em;
            text-transform: uppercase;
        }
        .form-control-custom {
            width: 100%;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: .7rem 1rem;
            color: var(--text);
            font-family: 'Inter', sans-serif;
            font-size: .93rem;
            outline: none;
            transition: border-color .2s, box-shadow .2s;
        }
        .form-control-custom:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(99,102,241,.25);
        }
        .form-control-custom option { background: var(--surface2); }
        .field-error { color: var(--danger); font-size: .8rem; margin-top: .3rem; display: block; }
        .validation-summary {
            background: rgba(244,63,94,.1);
            border: 1px solid rgba(244,63,94,.3);
            border-radius: 8px;
            padding: .9rem 1.2rem;
            margin-bottom: 1.5rem;
            color: var(--danger);
            font-size: .88rem;
        }
        .validation-summary ul { margin: 0; padding-left: 1.2rem; }
        .search-bar { display: flex; gap: .8rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
        .search-bar input {
            flex: 1;
            min-width: 200px;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: .65rem 1rem;
            color: var(--text);
            font-family: 'Inter', sans-serif;
            font-size: .9rem;
            outline: none;
            transition: border-color .2s;
        }
        .search-bar input:focus { border-color: var(--primary); }
        .search-bar input::placeholder { color: var(--text-muted); }
        .sort-select {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: .65rem 1rem;
            color: var(--text);
            font-family: 'Inter', sans-serif;
            font-size: .9rem;
            outline: none;
            cursor: pointer;
        }
        .success-banner { text-align: center; padding: 2rem; }
        .success-icon { font-size: 4rem; margin-bottom: 1rem; animation: pop .4s cubic-bezier(.175,.885,.32,1.275); }
        @@keyframes pop { 0% { transform: scale(0); } 100% { transform: scale(1); } }
        .success-title {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--success);
            margin-bottom: .4rem;
            text-transform: uppercase;
            letter-spacing: .05em;
        }
        .success-sub { color: var(--text-muted); }
        .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1.5rem; }
        .detail-item {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 1rem 1.2rem;
        }
        .detail-item .label {
            font-size: .75rem;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: var(--text-muted);
            font-weight: 600;
            margin-bottom: .3rem;
        }
        .detail-item .value { font-size: 1rem; font-weight: 600; color: var(--text); }
        .delete-box {
            background: rgba(244,63,94,.08);
            border: 1px solid rgba(244,63,94,.25);
            border-radius: 12px;
            padding: 1.5rem;
            margin: 1.5rem 0;
        }
        .site-footer {
            text-align: center;
            padding: 1.5rem;
            color: var(--text-muted);
            font-size: .82rem;
            border-top: 1px solid var(--border);
        }
        @@media (max-width: 576px) {
            .detail-grid { grid-template-columns: 1fr; }
            .site-nav .nav-links { gap: .8rem; }
        }
    </style>
</head>
<body>
    <nav class="site-nav">
        <a class="brand" asp-controller="Asset" asp-action="Index">Portfolio Takip</a>
        <ul class="nav-links">
            <li><a asp-controller="Asset" asp-action="Index">Varlıklar</a></li>
            <li><a asp-controller="Asset" asp-action="RegisterTransaction">İşlem Yap</a></li>
            <li><a asp-controller="Asset" asp-action="TransactionsList">Portföyüm</a></li>
        </ul>
    </nav>

    <div class="main-container">
        @RenderBody()
    </div>

    <footer class="site-footer">
        &copy; 2025 — LCEN362 Web Programming | PortfolioManagementMvc
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>