@model PortfolioManagementMvc.Models.TransactionModel

@{
    ViewData["Title"] = "İşlem Sil";
}

<div style="margin-bottom:20px;">
    <h2>İşlem Sil / İptal</h2>
    <p>Bu işlemi silmek istediğinizden emin misiniz?</p>
</div>

<div style="background:#fff; border:1px solid #ddd; border-radius:8px; padding:20px; max-width:500px;">
    <table class="table">
        <tr>
            <th>Yatırımcı Adı</th>
            <td>@Model.InvestorName</td>
        </tr>
        <tr>
            <th>E-posta</th>
            <td>@Model.InvestorEmail</td>
        </tr>
        <tr>
            <th>Adet</th>
            <td>@Model.Quantity</td>
        </tr>
        <tr>
            <th>Varlık</th>
            <td>@Model.Asset?.AssetSymbol - @Model.Asset?.AssetName</td>
        </tr>
    </table>

    <form asp-action="DeleteTransaction" asp-route-id="@Model.TransactionId" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">Evet, Sil</button>
        <a asp-controller="Asset" asp-action="TransactionsList" class="btn btn-secondary">Vazgeç</a>
    </form>
</div>