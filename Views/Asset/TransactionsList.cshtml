@model IEnumerable<PortfolioManagementMvc.Models.TransactionModel>

@{
    ViewData["Title"] = "Portföy Takip";
}

<h2>Portföy Takip</h2>
<p>Bugüne kadar yapılan tüm işlemler.</p>

@if (!Model.Any())
{
    <p>Henüz hiç işlem kaydedilmemiş.</p>
    <a asp-controller="Asset" asp-action="RegisterTransaction" class="btn btn-primary">+ İlk İşlemi Ekle</a>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Yatırımcı</th>
                <th>E-posta</th>
                <th>Adet</th>
                <th>Sembol</th>
                <th>Varlık Adı</th>
                <th>İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td>@t.TransactionId</td>
                    <td>@t.InvestorName</td>
                    <td>@t.InvestorEmail</td>
                    <td>@t.Quantity</td>
                    <td><strong>@t.Asset?.AssetSymbol</strong></td>
                    <td>@t.Asset?.AssetName</td>
                    <td>
                        <a asp-controller="Asset"
                           asp-action="DeleteTransaction"
                           asp-route-id="@t.TransactionId"
                           class="btn btn-danger btn-sm">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <p>Toplam <strong>@Model.Count()</strong> kayıt.</p>
}