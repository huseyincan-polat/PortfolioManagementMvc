@model IEnumerable<PortfolioManagementMvc.Models.AssetModel>

@{
    ViewData["Title"] = "Ana Sayfa - Portföy Takip";
}

<div class="container mt-4">
    <div class="card bg-dark text-white shadow border-0" style="background-color: #1e1e2f;">
        <div class="card-header border-0 bg-transparent">
            <h3 class="m-0 fw-bold"><i class="fa-solid fa-chart-line text-success me-2"></i> Varlık Listesi ve 2028 Tahminleri</h3>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover m-0">
                    <thead>
                        <tr class="text-muted">
                            <th class="ps-4">SEMBOLE</th>
                            <th>VARLIK ADI</th>
                            <th class="text-end">GÜNCEL FİYAT</th>
                            <th class="text-end">2028 TAHMİNİ</th>
                            <th class="text-center">HEDEF YIL</th>
                            <th class="text-center pe-4">İŞLEM</th>
                        </tr>
                    </thead>
                    <tbody class="align-middle">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-white">@item.AssetSymbol</td>
                                <td class="text-muted">@item.AssetName</td>
                                <td class="text-end text-success fw-bold">@item.CurrentPrice.ToString("N2") ₺</td>
                                <td class="text-end text-info fw-bold">@item.Forecast2028.ToString("N2") ₺</td>
                                <td class="text-center">
                                    <span class="badge bg-secondary rounded-pill">@item.TargetYear</span>
                                </td>
                                <td class="text-center pe-4">
                                    <a href="#" class="btn btn-primary btn-sm rounded-pill">İşlem Yap</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>